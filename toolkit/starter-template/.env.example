# ─────────────────────────────────────────────────
# Solana Starter Template — Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────

# Cluster — "devnet" or "mainnet-beta"
# Controls which Solana network your app connects to.
NEXT_PUBLIC_CLUSTER=mainnet-beta

# RPC endpoint — browser-safe URL (non-secret)
# Development: use the public endpoint or your RPC URL
# Production: point to /api/rpc (proxy) to keep your API key private
NEXT_PUBLIC_RPC_URL=/api/rpc

# Helius API key — SECRET, server-side only
# Get a free key at https://www.helius.dev
# Used by the /api/rpc proxy route — never use NEXT_PUBLIC_ for this
HELIUS_API_KEY=your_helius_api_key_here

# Sentry DSN — optional, for error monitoring
# Get a free DSN at https://sentry.io
SENTRY_DSN=
